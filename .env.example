# Server
HOST=0.0.0.0
PORT=8080

# PostgreSQL. Must be postgres:// or postgresql://.
DATABASE_URL=

# Required AI generation API
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Optional media enrichment APIs. Leave unset to skip video/photo search.
YOUTUBE_API_KEY=
IMAGE_API_KEY=

# Optional object storage for generated/downloaded dish photos.
# Leave the whole group unset to skip photo enrichment.
# If any value is set, the service validates the full group when photo enrichment runs.
# Use the vendor-neutral Tigris/S3-compatible env scheme.
# The bucket is private. Store object keys and generate signed URLs when reading.
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_PREFIX=app_barbara_sh_b010_homemichelinch_a42e73/
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_FORCE_PATH_STYLE=true
